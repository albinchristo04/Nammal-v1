# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (found in Supabase > Settings > Database)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ─── REDIS (Upstash) ──────────────────────────────────────────────────────────
# Create a free Redis DB at upstash.com → copy REST URL and token
UPSTASH_REDIS_REST_URL="https://[YOUR_DB].upstash.io"
UPSTASH_REDIS_REST_TOKEN="[YOUR_TOKEN]"

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-very-long-random-secret-here"
JWT_REFRESH_SECRET="another-very-long-random-secret-here"

# ─── SMS OTP (Fast2SMS) ───────────────────────────────────────────────────────
# Sign up at fast2sms.com → API > Dev API Key
FAST2SMS_API_KEY="your-fast2sms-api-key"

# ─── CLOUDINARY (Media Storage) ───────────────────────────────────────────────
# Sign up at cloudinary.com → Dashboard > API Keys
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── URLS ─────────────────────────────────────────────────────────────────────
# Local development
WEB_URL="http://localhost:3000"
API_URL="http://localhost:4000"

# Production (fill these when deploying)
# WEB_URL="https://nammal.in"
# API_URL="https://api.nammal.in"

# ─── NEXT.JS (web app) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ─── FIREBASE (Web Push / FCM) ───────────────────────────────────────────────
# Create a Firebase project at console.firebase.google.com
# Project Settings > General > Your apps > Web app > SDK snippet > Config
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSyCRUU59NN01tQ7UhkzvPiJBuBdbg17EcTc"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="nammal-app.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="nammal-app"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="nammal-app.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="7612752823"
NEXT_PUBLIC_FIREBASE_APP_ID="1:7612752823:web:5acbefbb2f74a309593e32"
# Project Settings > Cloud Messaging > Web Push certificates > Generate key pair → copy it here
NEXT_PUBLIC_FIREBASE_VAPID_KEY="BG2OoKNosIrGpJvd6Z50oFUwLqSm8jFekqUh5QWFNtLYwcfhY5NUZKY0p4KmbUw8yZtJdes9SpnZOVQstZ6Ww4I"

